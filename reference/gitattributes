# Normalize line endings for stable cross-platform diffs.
* text=auto eol=lf

# Markdown
*.md text eol=lf diff=markdown

# Data formats
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf

# Code
*.py text eol=lf
*.sh text eol=lf

# Shell scripts should keep LF even on Windows checkout
*.sh eol=lf

